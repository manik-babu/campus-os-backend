<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            padding: 30px;
            color: #000;
        }

        .container {
            border: 2px solid #000;
            padding: 25px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }

        .university {
            font-size: 26px;
            font-weight: bold;
        }

        .title {
            font-size: 18px;
            margin-top: 5px;
            font-weight: bold;
        }

        .info {
            margin-top: 20px;
            width: 100%;
            border-collapse: collapse;
        }

        .info td {
            padding: 6px 4px;
            font-size: 14px;
        }

        .label {
            font-weight: bold;
            width: 180px;
        }

        .course-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 25px;
        }

        .course-table th,
        .course-table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
            font-size: 14px;
        }

        .course-table th {
            background-color: #f2f2f2;
        }

        .signature-section {
            margin-top: 60px;
            display: flex;
            justify-content: space-between;
        }

        .signature {
            text-align: center;
            width: 200px;
        }

        .signature-line {
            border-top: 1px solid black;
            margin-top: 50px;
            padding-top: 5px;
            font-size: 14px;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            font-size: 12px;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- HEADER -->
        <div class="header">
            <div class="university">Uttara University</div>
            <div class="title">
                <%= student.exam %> Examination Admit Card
            </div>
        </div>

        <!-- STUDENT INFORMATION -->
        <table class="info">
            <tr>
                <td class="label">Student Name:</td>
                <td>
                    <%= student.name %>
                </td>
                <td class="label">ID No:</td>
                <td>
                    <%= student.idNo %>
                </td>
            </tr>

            <tr>
                <td class="label">Registration No:</td>
                <td>
                    <%= student.registrationNo %>
                </td>
                <td class="label">Batch:</td>
                <td>
                    <%= student.batch %>
                </td>
            </tr>

            <tr>
                <td class="label">Department:</td>
                <td>
                    <%= student.department %>
                </td>
                <td class="label">Program:</td>
                <td>
                    <%= student.program %>
                </td>
            </tr>

            <tr>
                <td class="label">Exam Date:</td>
                <td>
                    <%= student.date %>
                </td>
                <td></td>
                <td></td>
            </tr>
        </table>

        <!-- COURSE LIST -->
        <table class="course-table">
            <thead>
                <tr>
                    <th>SL</th>
                    <th>Course Code</th>
                    <th>Course Title</th>
                    <th>Credits</th>
                </tr>
            </thead>
            <tbody>
                <% student.courses.forEach((course, index)=> { %>
                    <tr>
                        <td>
                            <%= index + 1 %>
                        </td>
                        <td>
                            <%= course.code %>
                        </td>
                        <td>
                            <%= course.title %>
                        </td>
                        <td>
                            <%= course.credits %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>

        <!-- SIGNATURE AREA -->
        <div class="signature-section">

            <div class="signature">
                <div class="signature-line">
                    Controller of Examination
                </div>
            </div>

            <div class="signature">
                <div class="signature-line">
                    Authorized Signature
                </div>
            </div>

        </div>

        <!-- FOOTER -->
        <div class="footer">
            This admit card must be carried during every examination.
        </div>

    </div>

</body>

</html>
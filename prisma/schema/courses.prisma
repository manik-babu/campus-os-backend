model Course {
    id           String     @id @default(uuid())
    code         String     @unique
    title        String
    description  String?
    credits      Int
    departmentId String
    department   Department @relation(fields: [departmentId], references: [id])

    courseOfferings CourseOffering[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt

    @@map("courses")
}

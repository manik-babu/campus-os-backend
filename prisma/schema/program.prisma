model Program {
    id              String           @id @default(uuid())
    name            String           @unique
    shortName       String           @unique
    level           ProgramLevel
    description     String?
    departments     Department[]
    admissionForms  AdmissionForm[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    studentProfiles StudentProfile[]

    @@map("programs")
}

enum ProgramLevel {
    UNDERGRADUATE
    POSTGRADUATE
    PHD
}

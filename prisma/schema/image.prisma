model Image {
    id              String         @id @default(cuid())
    url             String
    publicId        String
    userId          String?        @unique
    user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
    admissionFormId String?        @unique
    admissionForm   AdmissionForm? @relation("admissionFormImage", fields: [admissionFormId], references: [id], onDelete: Cascade)
    sscDocId        String?        @unique
    sscDoc          AdmissionForm? @relation("sscDoc", fields: [sscDocId], references: [id], onDelete: Cascade)
    hscDocId        String?        @unique
    hscDoc          AdmissionForm? @relation("hscDoc", fields: [hscDocId], references: [id], onDelete: Cascade)
    createdAt       DateTime       @default(now())
    updatedAt       DateTime       @updatedAt

    @@map("images")
}

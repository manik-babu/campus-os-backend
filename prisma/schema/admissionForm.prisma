model AdmissionForm {
    id               String              @id @default(uuid())
    image            String?
    programId        String
    program          Program             @relation(fields: [programId], references: [id])
    departmentId     String
    department       Department          @relation(fields: [departmentId], references: [id])
    name             String
    email            String              @unique
    fatherName       String
    motherName       String
    birthDate        DateTime
    permanentAddress String
    presentAddress   String
    phoneNumber      String
    schoolName       String
    collegeName      String
    sscGpa           Decimal             @db.Decimal(3, 2)
    hscGpa           Decimal             @db.Decimal(3, 2)
    sscPassingYear   Int
    hscPassingYear   Int
    bloodGroup       String?
    sscDoc           String?
    hscDoc           String?
    gender           AdmissionUserGender
    createdAt        DateTime            @default(now())
    updatedAt        DateTime            @updatedAt
    status           AdmissionStatus     @default(PENDING)
    isPaidFee        Boolean             @default(false)

    @@map("admission_forms")
}

enum AdmissionStatus {
    PENDING
    APPROVED
    REJECTED
}

enum AdmissionUserGender {
    MALE
    FEMALE
    OTHER
}
